    {
      "path": "/modules",
      "name": "Modules",
      "bucket": "HEALTH",
      "primary_user": "platform-operator",
      "actionability": "View module status, feature coverage",
      "source": "module-registry"
    },
    {
      "path": "/procurement",
      "name": "Procurement",
      "bucket": "ACTION",
      "primary_user": "platform-operator",
      "actionability": "Generate procurement packs, validate evidence",
      "source": "@nzila/platform-procurement-proof"
    },
    {
      "path": "/architecture",
      "name": "Architecture",
      "bucket": "HEALTH",
      "primary_user": "platform-operator",
      "actionability": "View architecture health, package ownership, contract status",
      "source": "architecture-checks"
    }
